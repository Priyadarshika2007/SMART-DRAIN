# ============================================
# SUPABASE POSTGRESQL CONNECTION
# ============================================
# 
# Get your connection string from Supabase:
# 1. Go to https://app.supabase.com
# 2. Select your project
# 3. Click Settings → Database
# 4. Copy the connection string under "Connection pooling"
# 5. Replace [YOUR-PASSWORD] with your actual database password
#
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
# Example: postgresql://postgres:myPassword123@db.xyz.supabase.co:5432/postgres
#

DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.yourproject.supabase.co:5432/postgres

# Frontend URL allowed by CORS (required)
FRONTEND_URL=http://localhost:3000

# Frontend API base URL - used by React components for API calls
# For local development: http://localhost:5000
# For Render deployment: https://smart-drain-backend.onrender.com
REACT_APP_API_URL=https://smart-drain-backend.onrender.com

# Legacy variable name (still supported for backward compatibility)
REACT_APP_BACKEND_URL=https://YOUR_BACKEND_URL.onrender.com

# Supabase API keys (security guidance)
# Use SUPABASE_ANON_KEY in frontend only.
# Never expose SUPABASE_SERVICE_ROLE_KEY in frontend code.
SUPABASE_ANON_KEY=your_public_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_private_service_role_key

# ============================================
# NODE ENVIRONMENT
# ============================================
# Options: development, production, test
NODE_ENV=development

# ============================================
# SERVER CONFIGURATION
# ============================================
# Port the Express server will listen on
PORT=5000

# ============================================
# EMAIL ALERTS (GMAIL)
# ============================================
# Use a Gmail App Password, not your normal Gmail password.
EMAIL_USER=yourrealmail@gmail.com
EMAIL_PASS=your_gmail_app_password
ALERT_EMAIL=yourrealmail@gmail.com

